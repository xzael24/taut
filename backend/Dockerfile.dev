# ============================================================
# Dev Dockerfile for TAUT Backend — Hot-reload mode
# Mounts source code as volume, uses Gradle in continuous/watch mode
# ============================================================

# ── Single stage: keep Gradle + JDK for dev ─────────────────
FROM gradle:8.7-jdk21-alpine

WORKDIR /app

# Copy only build configuration first (for dependency caching)
COPY backend/settings.gradle.kts backend/build.gradle.kts ./
COPY backend/gradle ./gradle
COPY backend/gradlew ./gradlew

# Pre-download dependencies (cached layer)
RUN ./gradlew --no-daemon dependencies || true

# Source code will be mounted as a volume at runtime
# Use Gradle in continuous (watch) mode for hot reload
CMD ["./gradlew", "--no-daemon", "--continuous", "run"]

EXPOSE 8080
